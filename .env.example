# ═══════════════════════════════════════════════════════════════════════════
# FITNESS APP - Variables de Entorno (EJEMPLO)
# ═══════════════════════════════════════════════════════════════════════════
# Instrucciones:
# 1. Copia este archivo: cp .env.example .env
# 2. Edita .env con tus valores reales
# 3. NUNCA subas .env a GitHub
# ═══════════════════════════════════════════════════════════════════════════

# BASE DE DATOS
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fitness_db
DB_USERNAME=your_username
DB_PASSWORD=your_password

# JWT (genera en https://generate-secret.vercel.app/64)
JWT_SECRET_KEY=your_secret_key_here
JWT_EXPIRATION=86400000
